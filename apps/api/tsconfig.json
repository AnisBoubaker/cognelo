{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@cognara/contracts": [
        "../../packages/contracts/src/index.ts"
      ],
      "@cognara/activity-ui": [
        "../../packages/activity-ui/src/index.ts"
      ],
      "@cognara/core": [
        "../../packages/core/src/index.ts"
      ],
      "@cognara/db": [
        "../../packages/db/src/index.ts"
      ],
      "@cognara/activity-sdk": [
        "../../packages/activity-sdk/src/index.ts"
      ],
      "@cognara/activity-sdk/server": [
        "../../packages/activity-sdk/src/server.ts"
      ],
      "@cognara/plugin-homework-grader": [
        "../../packages/plugins/plugin-homework-grader/src/index.ts"
      ],
      "@cognara/plugin-homework-grader/server": [
        "../../packages/plugins/plugin-homework-grader/src/server.ts"
      ],
      "@cognara/plugin-parsons": [
        "../../packages/plugins/plugin-parsons/src/index.ts"
      ],
      "@cognara/plugin-parsons/server": [
        "../../packages/plugins/plugin-parsons/src/server.ts"
      ],
      "@cognara/plugin-placeholder": [
        "../../packages/plugins/plugin-placeholder/src/index.ts"
      ],
      "@cognara/plugin-placeholder/server": [
        "../../packages/plugins/plugin-placeholder/src/server.ts"
      ],
      "@cognara/config": [
        "../../packages/config/src/index.ts"
      ]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules"
  ]
}
