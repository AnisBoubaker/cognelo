{
  "name": "cognelo",
  "private": true,
  "version": "0.1.0",
  "description": "Modular intelligent tutoring system foundation for programming education.",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "dev": "set -a && . ./.env && set +a && npm run dev --workspace @cognelo/api & npm run dev:web",
    "dev:api": "set -a && . ./.env && set +a && npm run dev --workspace @cognelo/api",
    "dev:web": "set -a && . ./.env && set +a && npm run dev --workspace @cognelo/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace @cognelo/db",
    "db:migrate": "npm run db:migrate --workspace @cognelo/db",
    "db:seed": "npm run db:seed --workspace @cognelo/db",
    "db:studio": "npm run db:studio --workspace @cognelo/db"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.4.5"
  }
}
