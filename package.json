{
  "name": "cognelo",
  "private": true,
  "version": "0.1.0",
  "description": "Modular intelligent tutoring system foundation for programming education.",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "dev": "set -a && . ./.env && set +a && node ./scripts/dev.mjs",
    "dev:api": "set -a && . ./.env && set +a && npm run dev --workspace @cognelo/api",
    "dev:runner": "docker compose up -d web-design-runner",
    "dev:web": "set -a && . ./.env && set +a && npm run dev --workspace @cognelo/web",
    "dev:stop": "node ./scripts/stop-dev.mjs",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace @cognelo/db",
    "db:migrate": "npm run db:migrate --workspace @cognelo/db",
    "db:seed": "npm run db:seed --workspace @cognelo/db",
    "db:studio": "npm run db:studio --workspace @cognelo/db"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.4.5"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "16.2.4",
    "@next/swc-darwin-x64": "16.2.4",
    "@next/swc-linux-arm64-gnu": "16.2.4",
    "@next/swc-linux-arm64-musl": "16.2.4",
    "@next/swc-linux-x64-gnu": "16.2.4",
    "@next/swc-linux-x64-musl": "16.2.4",
    "@next/swc-win32-arm64-msvc": "16.2.4",
    "@next/swc-win32-x64-msvc": "16.2.4"
  }
}
