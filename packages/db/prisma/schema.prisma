generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseStatus {
  draft
  published
  archived
}

enum CourseMembershipRole {
  owner
  teacher
  ta
  student
}

enum MaterialKind {
  folder
  text
  markdown
  pdf
  link
  github_repo
  code_example
  dataset
  file
  module
}

enum ActivityLifecycle {
  draft
  published
  paused
  archived
}

enum CourseGroupStatus {
  draft
  published
}

enum CourseGroupParticipantRole {
  teacher
  ta
  student
}

enum PluginParsonsAttemptStatus {
  in_progress
  completed
  abandoned
}

enum PluginCodingExerciseExecutionKind {
  run
  submit
}

enum PluginCodingExerciseExecutionStatus {
  pending
  completed
  failed
}

model User {
  id              String             @id @default(cuid())
  email           String             @unique
  name            String?
  passwordHash    String
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  roles           UserRole[]
  courses         CourseMembership[]
  createdCourses  Course[]           @relation("CourseCreator")
  materials       CourseMaterial[]   @relation("MaterialCreator")
  activities      Activity[]         @relation("ActivityCreator")
  createdGroups   CourseGroup[]      @relation("CourseGroupCreator")
  groupParticipants CourseGroupParticipant[]
  groupMaterials  CourseGroupMaterial[] @relation("GroupMaterialCreator")
  parsonsAttempts PluginParsonsAttempt[]
  codingExerciseExecutions PluginCodingExerciseExecution[]

  @@index([email])
}

model Role {
  id          String     @id @default(cuid())
  key         String     @unique
  name        String
  description String?
  createdAt   DateTime   @default(now())
  users       UserRole[]
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Course {
  id          String             @id @default(cuid())
  title       String
  description String             @default("")
  status      CourseStatus       @default(draft)
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   User               @relation("CourseCreator", fields: [createdById], references: [id])
  memberships CourseMembership[]
  materials   CourseMaterial[]
  activities  Activity[]
  groups      CourseGroup[]

  @@index([status])
  @@index([createdById])
}

model CourseMembership {
  id        String               @id @default(cuid())
  courseId  String
  userId    String
  role      CourseMembershipRole
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  course    Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId, role])
  @@index([courseId])
  @@index([userId])
}

model CourseMaterial {
  id          String       @id @default(cuid())
  courseId    String
  parentId    String?
  title       String
  kind        MaterialKind
  body        String?
  url         String?
  metadata    Json         @default("{}")
  position    Int          @default(0)
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("MaterialCreator", fields: [createdById], references: [id])
  parent      CourseMaterial?  @relation("MaterialTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    CourseMaterial[] @relation("MaterialTree")
  groupVisibilityOverrides CourseGroupHiddenCourseMaterial[]

  @@index([courseId, position])
  @@index([courseId, parentId, position])
  @@index([kind])
}

model CourseGroup {
  id          String                @id @default(cuid())
  courseId    String
  title       String
  description String                @default("")
  status      CourseGroupStatus     @default(draft)
  availableFrom DateTime?
  availableUntil DateTime?
  createdById String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  course      Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User                  @relation("CourseGroupCreator", fields: [createdById], references: [id])
  materials   CourseGroupMaterial[]
  activities  CourseGroupActivity[]
  participants CourseGroupParticipant[]
  hiddenCourseMaterials CourseGroupHiddenCourseMaterial[]

  @@index([courseId, updatedAt])
  @@index([status, availableFrom, availableUntil])
  @@index([createdById])
}

model CourseGroupParticipant {
  id          String      @id @default(cuid())
  groupId      String
  userId       String?
  role         CourseGroupParticipantRole @default(student)
  firstName    String
  lastName     String
  email        String
  externalId   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  group        CourseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([groupId, email])
  @@index([groupId, createdAt])
  @@index([email])
  @@index([userId])
}

model CourseGroupMaterial {
  id          String                  @id @default(cuid())
  groupId     String
  parentId    String?
  title       String
  kind        MaterialKind
  body        String?
  url         String?
  metadata    Json                    @default("{}")
  position    Int                     @default(0)
  createdById String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  group       CourseGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User                    @relation("GroupMaterialCreator", fields: [createdById], references: [id])
  parent      CourseGroupMaterial?    @relation("CourseGroupMaterialTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    CourseGroupMaterial[]   @relation("CourseGroupMaterialTree")

  @@index([groupId, position])
  @@index([groupId, parentId, position])
  @@index([kind])
}

model CourseGroupActivity {
  id             String       @id @default(cuid())
  groupId        String
  activityId     String
  availableFrom  DateTime?
  availableUntil DateTime?
  config         Json         @default("{}")
  metadata       Json         @default("{}")
  position       Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  group          CourseGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  activity       Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([groupId, activityId])
  @@index([groupId, position])
  @@index([activityId])
}

model CourseGroupHiddenCourseMaterial {
  groupId          String
  courseMaterialId String
  createdAt        DateTime      @default(now())
  group            CourseGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  courseMaterial   CourseMaterial @relation(fields: [courseMaterialId], references: [id], onDelete: Cascade)

  @@id([groupId, courseMaterialId])
  @@index([courseMaterialId])
}

model ActivityType {
  id          String     @id @default(cuid())
  key         String     @unique
  name        String
  description String
  version     String     @default("0.1.0")
  metadata    Json       @default("{}")
  isEnabled   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  activities  Activity[]
}

model Activity {
  id             String            @id @default(cuid())
  courseId       String
  activityTypeId String
  title          String
  description    String            @default("")
  lifecycle      ActivityLifecycle @default(draft)
  config         Json              @default("{}")
  metadata       Json              @default("{}")
  position       Int               @default(0)
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  course         Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  activityType   ActivityType      @relation(fields: [activityTypeId], references: [id])
  createdBy      User              @relation("ActivityCreator", fields: [createdById], references: [id])
  groupAssignments CourseGroupActivity[]
  parsonsAttempts PluginParsonsAttempt[]
  codingExerciseHiddenTests PluginCodingExerciseHiddenTest[]
  codingExerciseExecutions PluginCodingExerciseExecution[]
  codingExerciseReferenceSolution PluginCodingExerciseReferenceSolution?

  @@index([courseId, position])
  @@index([activityTypeId])
  @@index([lifecycle])
}

model PluginParsonsAttempt {
  id                String                     @id @default(cuid())
  activityId        String
  userId            String
  status            PluginParsonsAttemptStatus @default(in_progress)
  latestState       Json                       @default("{}")
  resultSummary     Json                       @default("{}")
  checkCount        Int                        @default(0)
  resetCount        Int                        @default(0)
  moveCount         Int                        @default(0)
  indentCount       Int                        @default(0)
  startedAt         DateTime                   @default(now())
  lastInteractionAt DateTime                   @default(now())
  completedAt       DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  activity          Activity                   @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  events            PluginParsonsAttemptEvent[]

  @@index([activityId, userId, status])
  @@index([userId, status])
  @@index([activityId, lastInteractionAt])
}

model PluginParsonsAttemptEvent {
  id        String               @id @default(cuid())
  attemptId String
  type      String
  payload   Json                 @default("{}")
  createdAt DateTime             @default(now())
  attempt   PluginParsonsAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId, createdAt])
  @@index([type])
}

model PluginCodingExerciseHiddenTest {
  id             String   @id @default(cuid())
  activityId     String
  name           String
  stdin          String   @default("")
  expectedOutput String   @default("")
  orderIndex     Int      @default(0)
  isEnabled      Boolean  @default(true)
  weight         Int      @default(1)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  activity       Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId, orderIndex])
  @@index([activityId, isEnabled])
}

model PluginCodingExerciseReferenceSolution {
  id                String   @id @default(cuid())
  activityId        String   @unique
  sourceCode        String
  validationSummary Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  activity          Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model PluginCodingExerciseExecution {
  id                    String                             @id @default(cuid())
  activityId            String
  userId                String
  kind                  PluginCodingExerciseExecutionKind  @default(run)
  status                PluginCodingExerciseExecutionStatus @default(pending)
  languageKey           String
  judge0LanguageId      Int
  sourceCode            String
  stdin                 String?   @default("")
  expectedOutput        String?   @default("")
  judge0Token           String?
  stdout                String?
  stderr                String?
  compileOutput         String?
  message               String?
  timeSeconds           String?
  memoryKb              Int?
  judge0StatusId        Int?
  judge0StatusLabel     String?
  resultSummary         Json      @default("{}")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  activity              Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activityId, userId, createdAt])
  @@index([userId, createdAt])
  @@index([activityId, kind, createdAt])
  @@index([judge0Token])
}
