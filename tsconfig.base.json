{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@cognara/contracts": ["packages/contracts/src/index.ts"],
      "@cognara/core": ["packages/core/src/index.ts"],
      "@cognara/db": ["packages/db/src/index.ts"],
      "@cognara/activity-sdk": ["packages/activity-sdk/src/index.ts"],
      "@cognara/config": ["packages/config/src/index.ts"]
    }
  }
}
